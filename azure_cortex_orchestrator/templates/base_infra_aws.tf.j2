{#
  Base Terraform template for AWS scenarios.

  Provides a foundational AWS environment for the LLM to customize
  based on the specific attack scenario.

  Variables:
    - run_id: Unique run identifier
    - region: AWS region (default: us-east-1)
    - resource_name_prefix: Prefix for resource naming
#}

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = "{{ region | default('us-east-1') }}"

  default_tags {
    tags = {
      environment = "cortex-simulation"
      run_id      = "{{ run_id }}"
      managed_by  = "azure-cortex-orchestrator"
    }
  }
}

# ── VPC ──────────────────────────────────────────────────────────
resource "aws_vpc" "sim" {
  cidr_block           = "10.0.0.0/16"
  enable_dns_hostnames = true
  enable_dns_support   = true

  tags = {
    Name = "{{ resource_name_prefix }}vpc"
  }
}

resource "aws_subnet" "sim" {
  vpc_id     = aws_vpc.sim.id
  cidr_block = "10.0.1.0/24"

  tags = {
    Name = "{{ resource_name_prefix }}subnet"
  }
}

# ── IAM Role (for EC2 or Lambda) ──────────────────────────────────
resource "aws_iam_role" "sim" {
  name = "{{ resource_name_prefix }}role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
          Service = "ec2.amazonaws.com"
        }
      }
    ]
  })
}

# ── S3 Bucket ─────────────────────────────────────────────────────
resource "aws_s3_bucket" "sim" {
  bucket        = "{{ resource_name_prefix }}{{ run_id[:8] }}"
  force_destroy = true
}

# ── CloudTrail ────────────────────────────────────────────────────
resource "aws_cloudtrail" "sim" {
  name                          = "{{ resource_name_prefix }}trail"
  s3_bucket_name                = aws_s3_bucket.sim.id
  include_global_service_events = true
  is_multi_region_trail         = false
}

# ── Outputs ──────────────────────────────────────────────────────
output "vpc_id" {
  value = aws_vpc.sim.id
}

output "iam_role_arn" {
  value = aws_iam_role.sim.arn
}

output "s3_bucket_name" {
  value = aws_s3_bucket.sim.id
}
