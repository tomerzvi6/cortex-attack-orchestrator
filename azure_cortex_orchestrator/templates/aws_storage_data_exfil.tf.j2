{#
  Scenario: AWS S3 Data Exfiltration via Access Keys

  Deploys:
    - S3 bucket with simulated PII data
    - IAM user with full S3 access (misconfiguration)
    - Access keys for the user

  Variables:
    - run_id: Unique run identifier
    - region: AWS region (default: us-east-1)
    - resource_name_prefix: Prefix for resource naming
#}

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = "{{ region | default('us-east-1') }}"

  default_tags {
    tags = {
      environment = "cortex-simulation"
      run_id      = "{{ run_id }}"
      managed_by  = "azure-cortex-orchestrator"
    }
  }
}

# ── S3 Bucket ─────────────────────────────────────────────────────
resource "aws_s3_bucket" "sim" {
  bucket        = "{{ resource_name_prefix }}{{ run_id[:8] }}"
  force_destroy = true
}

# ── S3 Objects (simulated sensitive data — inline content) ────────
resource "aws_s3_object" "pii_records" {
  bucket  = aws_s3_bucket.sim.id
  key     = "data/pii-records.csv"
  content = "id,name,email,ssn\n1,John Doe,john@example.com,123-45-6789\n2,Jane Smith,jane@example.com,987-65-4321\n3,Bob Wilson,bob@example.com,456-78-9012\n"
}

resource "aws_s3_object" "financial_data" {
  bucket  = aws_s3_bucket.sim.id
  key     = "data/financial-records.csv"
  content = "account_id,balance,routing_number\nACCT-001,52340.00,021000021\nACCT-002,18290.50,026009593\nACCT-003,91005.75,021000021\n"
}

# ── IAM User (attacker) ─────────────────────────────────────────
resource "aws_iam_user" "sim" {
  name          = "{{ resource_name_prefix }}user"
  force_destroy = true
}

# ── Access Key ───────────────────────────────────────────────────
resource "aws_iam_access_key" "sim" {
  user = aws_iam_user.sim.name
}

# ── VULNERABLE: Inline policy granting full S3 access ─────────────
resource "aws_iam_user_policy" "sim" {
  name = "{{ resource_name_prefix }}s3-full-access"
  user = aws_iam_user.sim.name

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid      = "FullS3Access"
        Effect   = "Allow"
        Action   = "s3:*"
        Resource = [
          aws_s3_bucket.sim.arn,
          "${aws_s3_bucket.sim.arn}/*"
        ]
      }
    ]
  })
}

# ── Outputs ──────────────────────────────────────────────────────
output "s3_bucket_name" {
  value = aws_s3_bucket.sim.id
}

output "iam_user_name" {
  value = aws_iam_user.sim.name
}

output "access_key_id" {
  value = aws_iam_access_key.sim.id
}

output "secret_access_key" {
  value     = aws_iam_access_key.sim.secret
  sensitive = true
}
